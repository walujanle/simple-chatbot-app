# Optional public backend origin. Leave empty for same-origin /api routing.
VITE_API_BASE_URL=

# Optional comma-separated CSP origin allowlists.
# Cloudflare Web Analytics example:
# VITE_CSP_SCRIPT_ORIGINS=https://static.cloudflareinsights.com
# VITE_CSP_CONNECT_ORIGINS=https://cloudflareinsights.com
VITE_CSP_SCRIPT_ORIGINS=
VITE_CSP_CONNECT_ORIGINS=

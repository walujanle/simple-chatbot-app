{
  "name": "simple-chatbot-backend",
  "version": "0.2.3",
  "author": "Leonard Walujan",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./dist/app.js"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch src/index.ts",
    "build": "rimraf dist && cross-env NODE_ENV=production tsc --noEmit && cross-env NODE_ENV=production esbuild src/index.ts src/app.ts --bundle --packages=external --platform=node --format=esm --target=node24 --sourcemap --outdir=dist",
    "test": "cross-env NODE_ENV=test tsx --test --import ./tests/setup.mjs tests/unit/*.test.ts tests/integration/*.test.ts",
    "test:database": "cross-env NODE_ENV=test tsx scripts/database-smoke.ts",
    "start": "cross-env NODE_ENV=production node dist/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@hono/node-server": "^2.0.4",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "hono": "^4.12.25",
    "ipaddr.js": "^2.4.0",
    "kysely": "^0.29.2",
    "mysql2": "^3.22.5",
    "openai": "^6.42.0",
    "pg": "^8.21.0",
    "undici": "^8.4.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "cross-env": "^10.1.0",
    "esbuild": "^0.28.1",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}

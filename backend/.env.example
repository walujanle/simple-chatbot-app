# Required
FRONTEND_URL=https://chat.example.com
JWT_SECRET=replace-with-at-least-32-random-characters
CREDENTIAL_ENCRYPTION_KEY=replace-with-32-random-bytes-as-base64
DATABASE_URL=

# DATABASE_URL must be present. Leave it empty for SQLite at
# backend/database/chatbot.db, or provide a PostgreSQL/MySQL/MariaDB URL.
# A non-empty remote URL is required for ephemeral/serverless deployments.

# Optional server settings
PORT=3000
SESSION_TTL_HOURS=168
REGISTRATION_ENABLED=true

# Empty cookie values enable automatic secure defaults based on deployment.
COOKIE_SECURE=
COOKIE_SAME_SITE=

# Optional reverse proxy settings
TRUST_PROXY=false
TRUST_PROXY_HOPS=1

# Optional AI provider networking
ALLOW_PRIVATE_AI_ENDPOINTS=false
PROVIDER_TIMEOUT_MS=180000

# Optional search integrations
BRAVE_SEARCH_API_KEY=
SEARXNG_BASE_URL=
SEARCH_TIMEOUT_MS=10000
SEARCH_PAGE_FETCH_LIMIT=3

# Optional storage limits
MAX_CHATS_PER_USER=200
MAX_MESSAGES_PER_CHAT=1000

# DATABASE_URL examples:
# postgresql://user:password@host:5432/chatbot?sslmode=require
# mysql://user:password@host:3306/chatbot?ssl={"rejectUnauthorized":true}
# mariadb://user:password@host:3306/chatbot?ssl={"rejectUnauthorized":true}
